#\ \  \___|\ \  \|\  \ \  \_|\ \ \   __/|\ \  \|\  \ \  \|\  \ \  \  /  / | \   __/| \|___/  /|
# \ \  \    \ \  \\\  \ \  \ \\ \ \  \_|/_\ \   _  _\ \   __  \ \  \/  / / \ \  \_|/__   /  / /
#  \ \  \____\ \  \\\  \ \  \_\\ \ \  \_|\ \ \  \\  \\ \  \ \  \ \    / /   \ \  \_|\ \ /  /_/__
#   \ \_______\ \_______\ \_______\ \_______\ \__\\ _\\ \__\ \__\ \__/ /     \ \_______\\________\
#    \|_______|\|_______|\|_______|\|_______|\|__|\|__|\|__|\|__|\|__|/       \|_______|\|_______|



# Включаем mod_rewrite
RUN a2enmod rewrite

# Копируем проект
COPY . /var/www/html/

# Права
RUN chown -R www-data:www-data /var/www/html

EXPOSE 80
